{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moqentra.io/schemas/TrainingJobSpec/v1",
  "title": "TrainingJobSpec",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "moqentra.io/v1" },
    "kind": { "const": "TrainingJobSpec" },
    "metadata": { "$ref": "#/definitions/Metadata" },
    "spec": {
      "type": "object",
      "required": ["datasetId", "modelName"],
      "properties": {
        "datasetId": { "type": "string" },
        "datasetVersionId": { "type": "string" },
        "modelName": { "type": "string" },
        "framework": { "type": "string" },
        "hyperparameters": { "type": "object" },
        "resources": { "$ref": "#/definitions/ResourceQuantity" },
        "maxDuration": { "type": "string" },
        "retryPolicy": { "$ref": "#/definitions/RetryPolicy" }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "Metadata": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tenantId": { "type": "string" },
        "projectId": { "type": "string" },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "ResourceQuantity": {
      "type": "object",
      "properties": {
        "cpuCores": { "type": "integer", "minimum": 0 },
        "memoryGib": { "type": "integer", "minimum": 0 },
        "gpuCount": { "type": "integer", "minimum": 0 },
        "npuCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "RetryPolicy": {
      "type": "object",
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "backoff": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
