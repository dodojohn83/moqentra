{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moqentra.io/schemas/ApplicationSpec/v1",
  "title": "ApplicationSpec",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "moqentra.io/v1" },
    "kind": { "const": "ApplicationSpec" },
    "metadata": { "$ref": "#/definitions/Metadata" },
    "spec": {
      "type": "object",
      "required": ["modelVersionId"],
      "properties": {
        "modelVersionId": { "type": "string" },
        "runtime": { "type": "string", "enum": ["dyun-gu", "vllm", "triton", "custom"] },
        "bundleId": { "type": "string" },
        "resources": { "$ref": "#/definitions/ResourceQuantity" },
        "scaling": { "$ref": "#/definitions/ScalingPolicy" }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "Metadata": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tenantId": { "type": "string" },
        "projectId": { "type": "string" },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "ResourceQuantity": {
      "type": "object",
      "properties": {
        "cpuCores": { "type": "integer", "minimum": 0 },
        "memoryGib": { "type": "integer", "minimum": 0 },
        "gpuCount": { "type": "integer", "minimum": 0 },
        "npuCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "ScalingPolicy": {
      "type": "object",
      "properties": {
        "minReplicas": { "type": "integer", "minimum": 0 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetLatencyMs": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  }
}
